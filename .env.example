# Sanity project credentials
# Find these in the Sanity dashboard: https://www.sanity.io/manage
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# These mirror the above and are exposed to the client/build runtime
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Write token used only by scripts/seed-sanity.ts (never deployed)
# Generate at https://www.sanity.io/manage with "Editor" or "Deploy Studio" rights
SANITY_WRITE_TOKEN=
