---
import SanityImage from "../sanity/SanityImage.astro";
import { formatEventMeta } from "../../lib/format";
import type { EventGalleryCard } from "../../types/sanity";

interface Props {
  event: EventGalleryCard;
}

const { event } = Astro.props;
const meta = formatEventMeta({
  location: event.location,
  eventDate: event.eventDate,
  yearLabel: event.yearLabel,
  photoCount: event.photoCount
});
---

<a class="event-card" href={`/events/${event.slug}/`}>
  <div class="event-card__image">
    {event.coverImage && (
      <SanityImage image={event.coverImage} alt={event.title} sizes="(max-width: 1050px) 100vw, 33vw" fit="cover" />
    )}
    {!event.coverImage && (event as any).cover && (
      <img src={(event as any).cover} alt={event.title} loading="lazy" decoding="async" />
    )}
  </div>
  <div class="event-card__content">
    {event.subtitle && <span class="event-card__tag">{event.subtitle}</span>}
    <h2>{event.title}</h2>
    {meta && <p class="event-card__meta">{meta}</p>}
    <span class="event-card__view">View Gallery →</span>
  </div>
</a>
