---
import SanityImage from "../sanity/SanityImage.astro";
import { urlFor, type GalleryImageValue } from "../../lib/sanityImage";

interface Props {
  items: GalleryImageValue[] | undefined | null;
  ariaLabel?: string;
  itemClass?: string;
  containerClass?: string;
  sizes?: string;
}

const {
  items = [],
  ariaLabel,
  itemClass = "photo-masonry__item",
  containerClass = "photo-masonry",
  sizes = "(max-width: 600px) 100vw, (max-width: 1100px) 50vw, 33vw"
} = Astro.props;

const safeItems = Array.isArray(items) ? items.filter((i) => i?.image) : [];
---

<div class={containerClass} aria-label={ariaLabel}>
  {safeItems.map((item, i) => {
    const fullUrl = urlFor(item.image as any).width(2400).fit("max").auto("format").quality(85).url();
    const alt = item.image?.alt || `${ariaLabel || "Gallery"} image ${i + 1}`;
    return (
      <button class={itemClass} type="button" data-full={fullUrl} aria-label={alt}>
        <SanityImage image={item.image} sizes={sizes} fit="max" />
      </button>
    );
  })}
</div>
