---
import SanityImage from "../sanity/SanityImage.astro";
import { urlFor, type GalleryImageValue } from "../../lib/sanityImage";

interface Props {
  items: GalleryImageValue[] | undefined | null;
  ariaLabel?: string;
  itemClass?: string;
  containerClass?: string;
  sizes?: string;
}

const {
  items = [],
  ariaLabel,
  itemClass = "photo-masonry__item",
  containerClass = "photo-masonry",
  sizes = "(max-width: 600px) 100vw, (max-width: 1100px) 50vw, 33vw"
} = Astro.props;

const safeItems = Array.isArray(items) ? items.filter((i) => i?.image || (i as any)?.src) : [];
---

<div class={containerClass} aria-label={ariaLabel}>
  {safeItems.map((item, i) => {
    const localSrc = (item as any).src as string | undefined;
    const fullUrl = localSrc || urlFor(item.image as any).width(2400).fit("max").auto("format").quality(85).url();
    const alt = (item as any).alt || item.image?.alt || `${ariaLabel || "Gallery"} image ${i + 1}`;
    return (
      <button class={itemClass} type="button" data-full={fullUrl} aria-label={alt}>
        {localSrc ? (
          <img
            src={localSrc}
            width={(item as any).width}
            height={(item as any).height}
            alt={alt}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <SanityImage image={item.image} sizes={sizes} fit="max" />
        )}
      </button>
    );
  })}
</div>
